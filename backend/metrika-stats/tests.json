{
  "tests": [
    {
      "name": "OPTIONS request returns CORS headers",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": "",
      "bodyMatcher": "exact"
    },
    {
      "name": "GET stats returns summary",
      "method": "GET",
      "path": "/?view=stats",
      "expectedStatus": 200,
      "expectedBody": {
        "total_users": 8
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "GET users returns list",
      "method": "GET",
      "path": "/?view=users",
      "expectedStatus": 200,
      "expectedBody": {
        "total": 8
      },
      "bodyMatcher": "partial"
    }
  ]
}